# Frontend environment variables (Next.js). Copy to `.env.local` for local dev.
# On Vercel, set NEXT_PUBLIC_API_URL in Project → Settings → Environment Variables.

# Base URL of the backend API. NO trailing slash.
#   Local dev:   http://localhost:8000
#   Production:  https://attendance-api.onrender.com   (your Render web service URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
