# Backend environment variables. Copy to `.env` for local dev; on Render these
# are set in the dashboard / by render.yaml (never commit real secrets).

# "development" (localhost, HTTP, SameSite=Lax cookies) or
# "production" (HTTPS, Secure + SameSite=None cookies).
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins (no trailing slash).
# In production set this to your Vercel URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Random 32+ char string used for signing. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_THIS_WITH_A_SUPER_SECRET_KEY_IN_PRODUCTION

# Postgres with the pgvector extension. On Render use the Internal Database URL.
DATABASE_URL=postgresql://user:password@localhost:5435/attendancedb

# Redis — Celery broker + result backend. On Render use the Key Value internal URL.
REDIS_URL=redis://localhost:6379/0

# Cloudinary — permanent hosting for classroom/session photos.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=attendance_system
